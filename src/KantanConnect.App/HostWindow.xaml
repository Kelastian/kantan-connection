<Window x:Class="KantanConnect.App.HostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="clr-namespace:KantanConnect.App.Services"
        mc:Ignorable="d"
        Title="{Binding [HostWindow_Title], Source={x:Static services:LocalizationService.Instance}}"
        Height="380" Width="480"
        WindowStartupLocation="CenterOwner"
        Icon="kantan.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding [HostWindow_PinInstruction], Source={x:Static services:LocalizationService.Instance}}"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="{StaticResource SurfaceMutedBrush}"
                CornerRadius="8"
                Padding="24,16"
                HorizontalAlignment="Center">
            <TextBlock Text="{Binding PinWithSpacing}"
                       FontSize="48" FontWeight="Bold"
                       FontFamily="Consolas"
                       Foreground="{StaticResource AccentBrushDark}"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="0,16,0,0">
            <Ellipse Style="{StaticResource StatusDotStyle}"
                      Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}"
                      Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusText}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       Foreground="{StaticResource TextMutedBrush}"
                       MaxWidth="380"/>
        </StackPanel>

        <Button Grid.Row="3"
                Content="{Binding [HostWindow_StopSharingButton], Source={x:Static services:LocalizationService.Instance}}"
                Click="OnStopSharingClick"
                Style="{StaticResource BaseButtonStyle}"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"/>
    </Grid>
</Window>
