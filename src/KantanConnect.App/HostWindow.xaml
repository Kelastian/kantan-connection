<Window x:Class="KantanConnect.App.HostWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Kantan Connect — Compartiendo pantalla"
        Height="360" Width="480"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Compartí este PIN con el otro equipo:"
                   FontSize="16"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="#F0F0F0"
                CornerRadius="8"
                Padding="24,16"
                HorizontalAlignment="Center">
            <TextBlock Text="{Binding PinWithSpacing}"
                       FontSize="48" FontWeight="Bold"
                       FontFamily="Consolas"/>
        </Border>

        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   Foreground="Gray"
                   Margin="0,16,0,0"/>

        <Button Grid.Row="3"
                Content="Dejar de compartir"
                Click="OnStopSharingClick"
                Padding="16,8"
                HorizontalAlignment="Center"/>
    </Grid>
</Window>
