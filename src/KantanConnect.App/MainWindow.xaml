<Window x:Class="KantanConnect.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KantanConnect.App"
        mc:Ignorable="d"
        Title="Kantan Connect" Height="480" Width="640"
        MinHeight="360" MinWidth="480">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Kantan Connect"
                   FontSize="24" FontWeight="Bold"
                   Margin="0,0,0,4"/>

        <TextBlock Grid.Row="1"
                   Text="{Binding StatusText}"
                   Foreground="Gray"
                   Margin="0,0,0,12"/>

        <GroupBox Grid.Row="2" Header="Equipos disponibles en tu red">
            <Grid Margin="4">
                <ListView ItemsSource="{Binding Peers}"
                          SelectedItem="{Binding SelectedPeer}">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Nombre" Width="200" DisplayMemberBinding="{Binding DisplayName}"/>
                            <GridViewColumn Header="Dirección IP" Width="140" DisplayMemberBinding="{Binding IpAddress}"/>
                            <GridViewColumn Header="Puerto" Width="80" DisplayMemberBinding="{Binding TcpPort}"/>
                        </GridView>
                    </ListView.View>
                </ListView>

                <!-- Placeholder visible mientras no se descubrió ningún equipo todavía,
                     para que la tabla vacía no parezca un error o un bug. -->
                <TextBlock Text="Todavía no encontramos otros equipos con Kantan Connect abierto en tu red.&#x0a;Abrí la app en otra PC de la misma red para que aparezca acá."
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="Gray"
                           Margin="24"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Peers.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Conectar"
                    Command="{Binding ConnectCommand}"
                    Padding="16,8" Margin="0,0,8,0"/>
            <Button Command="{Binding ShareScreenCommand}"
                    Padding="16,8" MinWidth="180">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Content" Value="Compartir mi pantalla"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSharing}" Value="True">
                                <Setter Property="Content" Value="Dejar de compartir"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
