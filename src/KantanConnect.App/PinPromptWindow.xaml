<Window x:Class="KantanConnect.App.PinPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="clr-namespace:KantanConnect.App.Services"
        mc:Ignorable="d"
        Title="{Binding [PinPromptWindow_Title], Source={x:Static services:LocalizationService.Instance}}"
        Height="220" Width="360"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Icon="kantan.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   x:Name="PromptText"
                   TextWrapping="Wrap"
                   Margin="0,0,0,16"/>

        <TextBox Grid.Row="1"
                 x:Name="PinTextBox"
                 FontSize="24" FontFamily="Consolas"
                 HorizontalContentAlignment="Center"
                 MaxLength="6"
                 Padding="8"
                 BorderBrush="{StaticResource AccentBrush}"
                 BorderThickness="2"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding [PinPromptWindow_CancelButton], Source={x:Static services:LocalizationService.Instance}}"
                    Click="OnCancelClick" Style="{StaticResource BaseButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="{Binding [PinPromptWindow_ConnectButton], Source={x:Static services:LocalizationService.Instance}}"
                    Click="OnConfirmClick" Style="{StaticResource PrimaryButtonStyle}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
