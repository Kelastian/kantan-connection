<Window x:Class="KantanConnect.App.ViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:services="clr-namespace:KantanConnect.App.Services"
        mc:Ignorable="d"
        Title="{Binding [ViewerWindow_TitleConnecting], Source={x:Static services:LocalizationService.Instance}}"
        Height="720" Width="1100"
        MinHeight="360" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Icon="kantan.ico">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding ConnectedToHeading}"
                   FontSize="20" FontWeight="Bold"
                   Foreground="{StaticResource AccentBrushDark}"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="1">
            <!-- Fondo oscuro + mensaje de estado, visibles solo mientras no llegó
                 todavía ningún fotograma (ver DataTrigger más abajo). -->
            <Border Background="#202020">
                <TextBlock Text="{Binding StatusText}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="White"
                           Margin="24"/>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CurrentFrame}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </Border.Style>
            </Border>

            <Image x:Name="RemoteScreenImage"
                   Source="{Binding CurrentFrame}"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"
                   Focusable="True"
                   Cursor="Cross"
                   MouseMove="OnRemoteScreenMouseMove"
                   MouseDown="OnRemoteScreenMouseDown"
                   MouseUp="OnRemoteScreenMouseUp"
                   MouseWheel="OnRemoteScreenMouseWheel"
                   KeyDown="OnRemoteScreenKeyDown"
                   KeyUp="OnRemoteScreenKeyUp"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Ellipse Style="{StaticResource StatusDotStyle}"
                      Fill="{Binding ConnectionStatus, Converter={StaticResource ConnectionStatusToBrushConverter}}"
                      Margin="0,0,8,0"/>
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{StaticResource TextMutedBrush}"
                       VerticalAlignment="Center"
                       Margin="0,0,16,0"/>
            <Button Content="{Binding [ViewerWindow_CloseButton], Source={x:Static services:LocalizationService.Instance}}"
                    Click="OnCloseClick"
                    Style="{StaticResource BaseButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
